# Copy to .env.local and fill in. .env.local is gitignored.

# Privy App ID — https://dashboard.privy.io → Settings → App ID.
# Public, client-side identifier (hence NEXT_PUBLIC_). Not a secret; the App
# Secret (server-only) is a different value and must NEVER be NEXT_PUBLIC_.
NEXT_PUBLIC_PRIVY_APP_ID=

# Optional: Solana RPC used by the embedded-wallet UI / future trading page.
# Defaults to Solana's public mainnet RPC if unset (rate-limited; swap for
# Alchemy/Helius in production).
# NEXT_PUBLIC_SOLANA_RPC_URL=

# Optional: SERVER-ONLY Solana RPC for the trading terminal's holders list
# (getTokenLargestAccounts). NO NEXT_PUBLIC_ prefix — this URL embeds your
# Alchemy API key and must never reach the browser; it's read only in the
# /api/holders route handler. Get a free key at https://www.alchemy.com/rpc-api
# (the free tier covers this call). If unset, the holders route falls back to
# the public mainnet RPC, which rate-limits getTokenLargestAccounts (429) — so
# the list will often be empty without a key. Format:
#   https://solana-mainnet.g.alchemy.com/v2/<YOUR_KEY>
# ALCHEMY_RPC_URL=
